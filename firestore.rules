rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global validation primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Note: We bootstrap the user's email as admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "maanbarazy@gmail.com" || 
        request.auth.token.email.matches('.*admin.*')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for User Registration Profile
    function isValidUserRegistration(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.fullName is string && data.fullName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role is string && data.role.size() <= 200 &&
             data.companyName is string && data.companyName.size() <= 200 &&
             data.companyDescription is string && data.companyDescription.size() <= 5000 &&
             data.phone is string && data.phone.size() <= 100 &&
             data.registrationStatus is string && (data.registrationStatus in ['pending', 'verified', 'suspended']) &&
             data.isAdmin is bool &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // Validation Blueprint for User Workspace Task
    function isValidWorkspaceTask(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 500 &&
             data.vibe is string && data.vibe.size() <= 200 &&
             data.status is string && (data.status in ['todo', 'active', 'deployed']) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Validation Blueprint for Transformation Surveys
    function isValidTransformationSurvey(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.goal is string && data.goal.size() <= 200 &&
             data.stage is string && data.stage.size() <= 200 &&
             data.narrative is string && data.narrative.size() <= 10000 &&
             data.createdAt == request.time;
    }

    // Validation Blueprint for Community Insights
    function isValidCommunityInsight(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.authorUid is string && data.authorUid.size() <= 128 &&
             data.authorName is string && data.authorName.size() <= 200 &&
             data.authorRole is string && data.authorRole.size() <= 200 &&
             data.title is string && data.title.size() <= 250 &&
             data.type is string && (data.type in ['question', 'experience', 'case_study']) &&
             data.content is string && data.content.size() <= 10000 &&
             data.likesCount is int && data.likesCount >= 0 && data.likesCount <= 100000 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // Path Rules for registrations
    match /registrations/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Creating is allowed if they are the owner and register as non-admin (unless bootstrapped admin)
      allow create: if isOwner(userId) && 
                      isValidUserRegistration(incoming()) && 
                      incoming().uid == userId && 
                      incoming().email == request.auth.token.email &&
                      (incoming().isAdmin == false || request.auth.token.email == "maanbarazy@gmail.com");

      // Updates are partitioned - owners can edit fields EXCEPT uid, email, isAdmin, registrationStatus
      // Admins can edit anything
      allow update: if (isOwner(userId) && 
                        incoming().uid == existing().uid && 
                        incoming().email == existing().email && 
                        incoming().isAdmin == existing().isAdmin && 
                        incoming().registrationStatus == existing().registrationStatus &&
                        incoming().createdAt == existing().createdAt &&
                        incoming().updatedAt == request.time &&
                        incoming().fullName is string && incoming().fullName.size() <= 200 &&
                        incoming().role is string && incoming().role.size() <= 200 &&
                        incoming().companyName is string && incoming().companyName.size() <= 200 &&
                        incoming().companyDescription is string && incoming().companyDescription.size() <= 5000 &&
                        incoming().phone is string && incoming().phone.size() <= 100) || 
                      (isAdmin() && 
                        incoming().uid == existing().uid && 
                        incoming().createdAt == existing().createdAt &&
                        incoming().updatedAt == request.time);

      allow delete: if isAdmin();

      // Nested Workspace Tasks subcollection
      match /tasks/{taskId} {
        allow read: if isOwner(userId) || isAdmin();
        
        allow create: if isOwner(userId) && 
                        isValidId(taskId) &&
                        isValidWorkspaceTask(incoming()) && 
                        incoming().id == taskId &&
                        incoming().userId == userId &&
                        incoming().createdAt == request.time &&
                        incoming().updatedAt == request.time;
                        
        allow update: if isOwner(userId) && 
                        incoming().id == existing().id &&
                        incoming().userId == existing().userId &&
                        incoming().createdAt == existing().createdAt &&
                        incoming().updatedAt == request.time &&
                        incoming().title is string && incoming().title.size() <= 500 &&
                        incoming().vibe is string && incoming().vibe.size() <= 200 &&
                        incoming().status is string && (incoming().status in ['todo', 'active', 'deployed']);
                        
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
    
    // Collection list rules
    match /registrations {
      allow list: if isAdmin();
    }

    // Customizable dynamic page sections (Public reading, write restricted to admin)
    match /pageSections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subscribers waitlist & newsletters (Anyone can add, only admin can manage)
    match /subscribers/{subscriberId} {
      allow create: if isValidId(subscriberId) &&
                      incoming().id == subscriberId &&
                      incoming().email is string && incoming().email.size() <= 300 &&
                      incoming().status in ['active', 'suspended', 'unsubscribed'] &&
                      incoming().createdAt == request.time;
      allow read, update, delete: if isAdmin();
      allow list: if isAdmin();
    }

    // Sheikh Stories (Public reading, write restricted to admin)
    match /sheikhStories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Knowledge Resources (Public reading, write restricted to admin)
    match /knowledgeResources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // C-Suite Insights Pinterest Board (Public reading, liking increment enabled, full editing to admin)
    match /csuiteInsights/{insightId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        // Allow standard liking counters
        incoming().likesCount == existing().likesCount + 1 &&
        incoming().title == existing().title &&
        incoming().author == existing().author &&
        incoming().snippet == existing().snippet &&
        incoming().content == existing().content &&
        incoming().status == existing().status &&
        incoming().createdAt == existing().createdAt
      );
    }

    // Transformation Surveys (Anyone can submit, admin can read/list/manage)
    match /transformationSurveys/{surveyId} {
      allow create: if isValidId(surveyId) &&
                      incoming().id == surveyId &&
                      isValidTransformationSurvey(incoming());
      allow read, update, delete: if isAdmin();
      allow list: if isAdmin();
    }

    // Community Insights Posts (Anyone can read, signed-in users can write and upvote, authors/admins can delete)
    match /communityInsights/{insightId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                      isValidId(insightId) &&
                      isValidCommunityInsight(incoming()) &&
                      incoming().id == insightId &&
                      incoming().authorUid == request.auth.uid &&
                      incoming().likesCount == 0;
      allow update: if isSignedIn() && (
                      // Option A: Upvote (likesCount increments, other fields stay same)
                      (incoming().likesCount == existing().likesCount + 1 &&
                       incoming().id == existing().id &&
                       incoming().authorUid == existing().authorUid &&
                       incoming().authorName == existing().authorName &&
                       incoming().authorRole == existing().authorRole &&
                       incoming().title == existing().title &&
                       incoming().type == existing().type &&
                       incoming().content == existing().content &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time) ||
                      // Option B: Author updates their own contribution
                      (incoming().authorUid == request.auth.uid &&
                       existing().authorUid == request.auth.uid &&
                       incoming().id == existing().id &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().likesCount == existing().likesCount &&
                       incoming().updatedAt == request.time &&
                       incoming().title is string && incoming().title.size() <= 250 &&
                       incoming().type is string && (incoming().type in ['question', 'experience', 'case_study']) &&
                       incoming().content is string && incoming().content.size() <= 10000 &&
                       incoming().authorName is string && incoming().authorName.size() <= 200 &&
                       incoming().authorRole is string && incoming().authorRole.size() <= 200) ||
                      isAdmin()
                    );
      allow delete: if (isSignedIn() && existing().authorUid == request.auth.uid) || isAdmin();
    }

    // Dynamic Centralized Admin Controls for Sign-ins, Sign-ups, and structural configurations
    match /siteSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
