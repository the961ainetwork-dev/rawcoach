{
  "entities": {
    "userProfile": {
      "title": "User Profile Info",
      "description": "User profile with last active daily active user tracker",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "lastActive": { "type": "string" },
        "lastActiveTimestamp": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "lastActive"]
    },
    "userRegistration": {
      "title": "User Registration Profile",
      "description": "Information stored on signup of founders and CEOs",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "companyName": { "type": "string" },
        "companyDescription": { "type": "string" },
        "phone": { "type": "string" },
        "registrationStatus": { "type": "string", "enum": ["pending", "verified", "suspended"] },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "createdAt", "updatedAt"]
    },
    "userWorkspaceTask": {
      "title": "User Workspace Task",
      "description": "Client-specific automated tactical actions and notes stored in their workspace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "vibe": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "active", "deployed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "status", "createdAt", "updatedAt"]
    },
    "dynamicPageSection": {
      "title": "Dynamic Page Section",
      "description": "A customized content section dynamically placed on home or separate views",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string" },
        "layoutType": { "type": "string", "enum": ["standard", "image-left", "bento", "dark-slate"] },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "createdAt"]
    },
    "subscriberRecord": {
      "title": "Subscriber Record",
      "description": "A newsletter or waitlist subscription record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended", "unsubscribed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "status", "createdAt"]
    },
    "sheikhStory": {
      "title": "Sheikh Story",
      "description": "A historic business story detailing real-world sovereign-grade cases and tactical reports",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string" },
        "year": { "type": "string" },
        "author": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "author", "createdAt"]
    },
    "knowledgeResource": {
      "title": "Knowledge Resource",
      "description": "A reference guide, audit benchmark, cheatsheet, or training roadmap",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["guide", "cheatsheet", "whitepaper", "roadmap"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "description", "createdAt"]
    },
    "csuiteInsight": {
      "title": "C-Suite Insight",
      "description": "Pinterest-style business insight board cards for high-density strategic reading",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "role": { "type": "string" },
        "snippet": { "type": "string" },
        "content": { "type": "string" },
        "bgColor": { "type": "string" },
        "tag": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "author", "snippet", "content", "status", "createdAt"]
    },
    "transformationSurveyDoc": {
      "title": "Transformation Survey",
      "description": "User questionnaire entries regarding AI/X transformation experience",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "organizationName": { "type": "string" },
        "goal": { "type": "string" },
        "stage": { "type": "string" },
        "bottleneck": { "type": "string" },
        "narrative": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "goal", "stage", "narrative", "createdAt"]
    },
    "communityInsight": {
      "title": "Community Insight Post",
      "description": "User generated questions, transition experiences, and peer case studies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["question", "experience", "case_study"] },
        "content": { "type": "string" },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorUid", "authorName", "title", "type", "content", "likesCount", "createdAt", "updatedAt"]
    },
    "blogPost": {
      "title": "Blog Post Item",
      "description": "Expert B2B marketing insights, guides and industry news articles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "author": { "type": "string" },
        "readTime": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "registrations/{userId}": {
      "schema": "userRegistration",
      "description": "User registration profiles and coaching status"
    },
    "registrations/{userId}/tasks/{taskId}": {
      "schema": "userWorkspaceTask",
      "description": "Tactical actions and tracking notes belonging to the user"
    },
    "pageSections/{sectionId}": {
      "schema": "dynamicPageSection",
      "description": "Customizable homepage sections and content added by admin"
    },
    "subscribers/{subscriberId}": {
      "schema": "subscriberRecord",
      "description": "Email newsletter list records"
    },
    "sheikhStories/{storyId}": {
      "schema": "sheikhStory",
      "description": "Dynamic sheikh stories detailing real-world legacy cases and structural audits"
    },
    "knowledgeResources/{resourceId}": {
      "schema": "knowledgeResource",
      "description": "Downloadable learning resources, cheat sheets, and audit frameworks"
    },
    "csuiteInsights/{insightId}": {
      "schema": "csuiteInsight",
      "description": "Enterprise C-Suite Insight items laid out in Pinterest-style grid"
    },
    "transformationSurveys/{surveyId}": {
      "schema": "transformationSurveyDoc",
      "description": "Submitted questionnaires on AI/X transformation experience"
    },
    "communityInsights/{insightId}": {
      "schema": "communityInsight",
      "description": "User generated questions, transition experiences, and peer case studies"
    },
    "users/{userId}": {
      "schema": "userProfile",
      "description": "User daily active and login tracking profile metadata documents"
    },
    "blogPosts/{postId}": {
      "schema": "blogPost",
      "description": "B2B point marketing business blog post entries managed by system administrators"
    }
  }
}
